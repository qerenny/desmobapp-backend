  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const dayMs = 24 * 60 * 60 * 1000;",
          "const tomorrow = new Date(Date.now() + dayMs);",
          "const bookingDate = tomorrow.toISOString().slice(0, 10);",
          "pm.collectionVariables.set('bookingDate', bookingDate);",
          "pm.collectionVariables.set('holdStartTime', `${bookingDate}T07:00:00Z`);",
          "pm.collectionVariables.set('holdEndTime', `${bookingDate}T08:00:00Z`);",
          "pm.collectionVariables.set('analyticsStartDate', bookingDate);",
          "pm.collectionVariables.set('analyticsEndDate', bookingDate);",
          "pm.collectionVariables.set('createdVenueName', `Postman Venue ${Date.now()}`);",
          "pm.collectionVariables.set('layoutSeatLabel', `PM-${String(Date.now()).slice(-6)}`);"
        ]
      }
    }
  ],
